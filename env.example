# ─── Orbi environment ──────────────────────────────────────────────────────
# Copy this to .env and fill in your values. Never commit .env to git.

# --- API keys (required) ---
GEMINI_API_KEY=your_gemini_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# --- Mode ---
# 1 on Mac (mock hardware), 0 on Jetson (real hardware)
ORBI_DEV_MODE=1

# --- LLM backend ---
# 1 = Gemini (cloud, needs GEMINI_API_KEY)
# 2 = Gemma 4 via Ollama (local, no internet needed)
ORBI_LLM=1

# --- Voice ---
# ElevenLabs voice id. Default is "Bella" (warm, neutral).
# Browse voices: https://elevenlabs.io/app/voice-library
ORBI_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# --- Hardware (only matters when ORBI_DEV_MODE=0) ---
ORBI_ESP32_PORT=/dev/ttyACM0
ORBI_CAMERA=0
